# ─── XPS Intelligence Frontend — Local Environment ────────────────────────────
# Copy this file to .env.local and fill in real values.
# .env.local is gitignored and must NEVER be committed.

# ─── Backend API (Express Gateway) ────────────────────────────────────────────
# URL of the Express API gateway (api/gateway.js).
# Next.js rewrites /api/* requests to this origin so that browser requests
# stay same-origin and avoid CORS issues.
#
# Development defaults:
#   Express gateway → http://localhost:3000   (npm run gateway)
#   FastAPI agent   → http://localhost:8000   (npm run agent:server)
#
# Production: set to your Railway / hosted gateway URL.
NEXT_PUBLIC_API_URL=http://localhost:3000

# ─── Optional: Feature Flags ──────────────────────────────────────────────────
# Set to "true" to enable React Query DevTools in development.
NEXT_PUBLIC_DEV_TOOLS=false
