{
  "version": 2,
  "name": "xps-intelligence-dashboard",
  "buildCommand": "cd dashboard && npm install && npm run build",
  "outputDirectory": "dashboard/out",
  "installCommand": "cd dashboard && npm install",
  "framework": null,
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ],
  "env": {
    "NEXT_PUBLIC_BASE_PATH": ""
  }
}
