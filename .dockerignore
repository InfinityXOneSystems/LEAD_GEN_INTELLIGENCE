# Python
__pycache__/
*.pyc
*.pyo
*.pyd

# Virtual env
venv/
.venv/
.env
.env.*

# Node – exclude ALL node_modules so COPY . . in Dockerfile.gateway never
# copies host-built binaries into the container image (would bloat the image
# and could break native modules compiled for a different platform/arch).
node_modules/
frontend/node_modules/
dashboard/node_modules/

# Build artefacts – source is copied from the repo; compiled output is built
# inside the container and must not be stale-cached from the host.
frontend/dist/
frontend/.vite/
frontend/playwright-report/
frontend/test-results/
dashboard/.next/
dashboard/out/

# Git
.git
.gitignore

# Logs
logs/
*.log

# Docker
docker-compose*.yml

# IDE
.vscode
.idea

# OS
.DS_Store
Thumbs.db

# Test / CI artefacts
coverage/
*.lcov
*.xml
htmlcov/
.pytest_cache/

# Docs (not needed at runtime)
docs/
AUDIT/
*.md
