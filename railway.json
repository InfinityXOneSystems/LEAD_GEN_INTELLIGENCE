{
  "services": {
    "api-gateway": {
      "type": "nodejs",
      "startCommand": "node api/gateway.js",
      "buildCommand": "npm install"
    },
    "worker": {
      "type": "python",
      "startCommand": "python -m task_queue.worker",
      "buildCommand": "pip install -r requirements.txt"
    }
  }
}
