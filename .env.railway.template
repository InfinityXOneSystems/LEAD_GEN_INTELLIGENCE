# ═══════════════════════════════════════════════════════════════
# RAILWAY DEPLOYMENT ENVIRONMENT VARIABLES
# Copy to Railway dashboard → Project Settings → Variables
# ═══════════════════════════════════════════════════════════════

# ─── Core Application ───────────────────────────────────────────
NODE_ENV=production
# PORT is set automatically by Railway; only override for local testing
PORT=8000
LOG_LEVEL=info

# ─── Database (AWS RDS PostgreSQL) ─────────────────────────────
# Format: postgresql://user:password@host:5432/database
DATABASE_URL=postgresql://user:password@your-rds-endpoint:5432/xps_db

# ─── Redis Queue ───────────────────────────────────────────────
# Format: redis://user:password@host:port
REDIS_URL=redis://:password@your-redis-endpoint:6379/0

# ─── LLM Configuration (Groq) ───────────────────────────────────
LLM_PROVIDER=groq
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama3-8b-8192

# Optional: Fallback LLM Providers
OPENAI_API_KEY=your_openai_key_here
ANTHROPIC_API_KEY=your_anthropic_key_here

# ─── Vector Database (Qdrant) ───────────────────────────────────
QDRANT_URL=http://your-qdrant-endpoint:6333
QDRANT_API_KEY=your_qdrant_api_key

# ─── Local LLM (Ollama) - Optional ─────────────────────────────
OLLAMA_BASE_URL=http://your-ollama-endpoint:11434
OLLAMA_MODEL=llama3.2

# ─── GitHub Integration ────────────────────────────────────────
GITHUB_TOKEN=your_github_token_here

# ─── Agent Configuration ───────────────────────────────────────
# AGENT_PORT controls the Python FastAPI agent server (agent_core.api)
# PORT (above) controls the Node.js API gateway
AGENT_PORT=8000
WORKER_MAX_RETRIES=3
WORKER_POLL_TIMEOUT=5

# ─── Scraping Configuration ────────────────────────────────────
SCRAPING_RATE_LIMIT=10
PROXY_ENABLED=false
PROXY_URL=

# ─── CORS Configuration ────────────────────────────────────────
CORS_ALLOWED_ORIGINS=https://your-frontend-domain.com

# ─── Monitoring & Logging ──────────────────────────────────────
SENTRY_DSN=
DATADOG_API_KEY=
