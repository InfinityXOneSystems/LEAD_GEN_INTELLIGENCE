# ═══════════════════════════════════════════════════════════════
# RAILWAY DEPLOYMENT ENVIRONMENT VARIABLES
# Copy to Railway dashboard → Project Settings → Variables
#
# Services required in Railway project:
#   1. Backend  – this service (FastAPI, python:3.11)
#   2. Postgres – Railway managed PostgreSQL plugin
#   3. Redis    – Railway managed Redis plugin
#   4. Ollama   – Custom service: ollama/ollama image, port 11434
#
# Railway auto-wires ${{Postgres.DATABASE_URL}} and ${{Redis.REDIS_URL}}
# when those plugins are added to the same project.  Add the variables
# below to the Backend service manually.
# ═══════════════════════════════════════════════════════════════

# ─── Core Application ───────────────────────────────────────────
# PORT is set automatically by Railway; only override for local testing
PORT=8000
LOG_LEVEL=info

# ─── Database (Railway Postgres plugin) ────────────────────────
# Railway auto-provides ${{Postgres.DATABASE_URL}} — paste the resolved
# value here or use the reference variable directly in the Railway UI.
DATABASE_URL=${{Postgres.DATABASE_URL}}

# ─── Redis Queue (Railway Redis plugin) ────────────────────────
# Railway auto-provides ${{Redis.REDIS_URL}} — paste the resolved value
# here or use the reference variable directly in the Railway UI.
REDIS_URL=${{Redis.REDIS_URL}}

# ─── Ollama (Railway Ollama service) ───────────────────────────
# Add an ollama/ollama:latest service to the Railway project, expose
# port 11434, then reference it here.  The private domain is available
# as ${{Ollama.RAILWAY_PRIVATE_DOMAIN}} inside the same environment.
# Format: http://<private-domain>:11434
OLLAMA_BASE_URL=http://${{Ollama.RAILWAY_PRIVATE_DOMAIN}}:11434
OLLAMA_MODEL=llama3.2

# ─── LLM Configuration ─────────────────────────────────────────
# "auto"  → Groq first, then Ollama, then OpenAI
# "groq"  → Cloud Groq only (fastest, no GPU required)
# "ollama"→ Local Ollama only (Railway Ollama service or Docker Desktop)
LLM_PROVIDER=auto
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama3-8b-8192

# Optional: OpenAI fallback
OPENAI_API_KEY=your_openai_key_here
OPENAI_MODEL=gpt-4o-mini

# ─── CORS / Frontend Integration ───────────────────────────────
# Comma-separated list of allowed frontend origins.
# Add the XPS-INTELLIGENCE-FRONTEND deployment URL here.
# Supports exact origins and Railway/Vercel preview patterns.
CORS_ALLOWED_ORIGINS=https://xps-intelligence.vercel.app,https://xps-intelligence-*.vercel.app,http://localhost:5173,http://localhost:3000
FRONTEND_URL=https://xps-intelligence.vercel.app

# ─── GitHub Integration ────────────────────────────────────────
GITHUB_TOKEN=your_github_token_here

# ─── Agent / Worker Configuration ─────────────────────────────
WORKER_MAX_RETRIES=3
WORKER_POLL_TIMEOUT=5
SCRAPER_CONCURRENCY=10
MAX_LEADS_PER_DAY=100000

# ─── Scraping Configuration ────────────────────────────────────
SCRAPING_RATE_LIMIT=10
PROXY_ENABLED=false
PROXY_URL=

# ─── Security ──────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
SECRET_KEY=change-me-generate-with-openssl

# ─── Monitoring & Logging ──────────────────────────────────────
SENTRY_DSN=
