{
  "openapi": "3.1.0",
  "info": {
    "title": "XPS Lead Intelligence GPT Actions API",
    "description": "Exposes the Lead Gen Intelligence platform to a Custom GPT / Copilot Mobile. Allows the GPT to retrieve leads, score prospects, trigger scraping, run the full pipeline, manage outreach templates, run validation, and monitor system status.",
    "version": "2.0.0"
  },
  "servers": [
    {
      "url": "http://localhost:3100",
      "description": "Local dev server – replace with your production URL when deployed"
    }
  ],
  "paths": {
    "/status": {
      "get": {
        "operationId": "getStatus",
        "summary": "Get system status",
        "description": "Returns overall system health including the current lead count and number of pending tasks.",
        "responses": {
          "200": {
            "description": "System status",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StatusResponse"
                }
              }
            }
          }
        }
      }
    },
    "/leads": {
      "get": {
        "operationId": "getLeads",
        "summary": "List stored leads",
        "description": "Returns all leads currently stored in the system.",
        "parameters": [
          {
            "name": "limit",
            "in": "query",
            "description": "Maximum number of leads to return",
            "required": false,
            "schema": {
              "type": "integer",
              "minimum": 1
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of leads",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/LeadsResponse"
                }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "upsertLead",
        "summary": "Add or update a lead",
        "description": "Adds a new lead or updates an existing one matched by company + city.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/Lead"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Lead saved",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": { "type": "boolean" },
                    "lead_count": { "type": "integer" }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Missing required field",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          }
        }
      }
    },
    "/score": {
      "post": {
        "operationId": "scoreLead",
        "summary": "Score a lead",
        "description": "Accepts a lead object and returns a numeric priority score (0–50).",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/Lead"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Score result",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "score": { "type": "integer", "minimum": 0, "maximum": 50 },
                    "lead": { "$ref": "#/components/schemas/Lead" }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Invalid input",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          }
        }
      }
    },
    "/tasks": {
      "get": {
        "operationId": "getTasks",
        "summary": "List roadmap tasks",
        "description": "Returns all tasks from the project todo list.",
        "parameters": [
          {
            "name": "status",
            "in": "query",
            "description": "Filter tasks by status (e.g. pending, complete)",
            "required": false,
            "schema": {
              "type": "string",
              "enum": ["pending", "complete"]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Task list",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TasksResponse"
                }
              }
            }
          }
        }
      }
    },
    "/scrape": {
      "post": {
        "operationId": "triggerScrape",
        "summary": "Trigger the lead scraper",
        "description": "Runs the Google Maps scraper and stores new leads to disk.",
        "responses": {
          "200": {
            "description": "Scraper output",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": { "type": "boolean" },
                    "output": { "type": "string" }
                  }
                }
              }
            }
          },
          "500": {
            "description": "Scraper error",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          }
        }
      }
    },
    "/outreach/templates": {
      "get": {
        "operationId": "getOutreachTemplates",
        "summary": "List outreach templates",
        "description": "Returns all available email outreach templates.",
        "responses": {
          "200": {
            "description": "Templates list",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "templates": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/OutreachTemplate"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/outreach/send": {
      "post": {
        "operationId": "sendOutreach",
        "summary": "Record an outreach action",
        "description": "Records that a specific outreach template was sent to a lead.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["lead", "template_id"],
                "properties": {
                  "lead": { "$ref": "#/components/schemas/Lead" },
                  "template_id": {
                    "type": "string",
                    "description": "ID of the outreach template to use"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Outreach recorded",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": { "type": "boolean" },
                    "outreach": {
                      "type": "object",
                      "properties": {
                        "template_id": { "type": "string" },
                        "sent_at": { "type": "string", "format": "date-time" }
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Missing required fields",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          }
        }
      }
    },
    "/pipeline/run": {
      "post": {
        "operationId": "runPipeline",
        "summary": "Run the scoring + export pipeline",
        "description": "Executes the scoring pipeline followed by the JSON snapshot export. Use this to trigger a full data refresh from Copilot Mobile or a Custom GPT.",
        "responses": {
          "200": {
            "description": "Pipeline completed",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": { "type": "boolean" },
                    "scoring_output": { "type": "string" },
                    "export_output": { "type": "string" }
                  }
                }
              }
            }
          },
          "500": {
            "description": "Pipeline error",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          }
        }
      }
    },
    "/validate": {
      "post": {
        "operationId": "validateLeads",
        "summary": "Run the lead validation pipeline",
        "description": "Validates all stored leads and writes validation_report.json, duplicates.json, and invalid_leads.json to data/leads/.",
        "responses": {
          "200": {
            "description": "Validation summary",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": { "type": "boolean" },
                    "summary": { "$ref": "#/components/schemas/ValidationSummary" }
                  }
                }
              }
            }
          },
          "500": {
            "description": "Validation error",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          }
        }
      }
    },
    "/export": {
      "get": {
        "operationId": "exportSnapshot",
        "summary": "Export JSON snapshot for the dashboard",
        "description": "Reads leads from PostgreSQL (or falls back to JSON) and writes dashboard-ready scored_leads.json and scoring_report.json files.",
        "responses": {
          "200": {
            "description": "Export output",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": { "type": "boolean" },
                    "output": { "type": "string" }
                  }
                }
              }
            }
          },
          "500": {
            "description": "Export error",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          }
        }
      }
    },
    "/workspace/status": {
      "get": {
        "operationId": "getWorkspaceStatus",
        "summary": "Check Google Workspace configuration",
        "description": "Returns whether Google Workspace (Gmail, Sheets, Drive, Calendar) credentials are configured.",
        "responses": {
          "200": {
            "description": "Workspace configuration status",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": { "type": "boolean" },
                    "configured": { "type": "boolean" },
                    "missing": { "type": "array", "items": { "type": "string" } }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/workspace/sheets/export": {
      "post": {
        "operationId": "exportLeadsToSheets",
        "summary": "Export leads to Google Sheets",
        "description": "Creates a new Google Sheets spreadsheet populated with all stored leads.",
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "title": { "type": "string", "description": "Spreadsheet title (optional)" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Spreadsheet created",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": { "type": "boolean" },
                    "spreadsheetId": { "type": "string" },
                    "url": { "type": "string" }
                  }
                }
              }
            }
          },
          "500": { "description": "Error", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      }
    },
    "/workspace/gmail/send": {
      "post": {
        "operationId": "gmailSendEmail",
        "summary": "Send an email via Gmail",
        "description": "Sends an email using the configured Gmail account (requires Google OAuth credentials).",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["to", "subject", "body"],
                "properties": {
                  "to": { "type": "string", "format": "email" },
                  "subject": { "type": "string" },
                  "body": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Email sent",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": { "type": "boolean" },
                    "message_id": { "type": "string" }
                  }
                }
              }
            }
          },
          "500": { "description": "Error", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      }
    },
    "/workspace/gmail/messages": {
      "get": {
        "operationId": "gmailListMessages",
        "summary": "List Gmail messages",
        "description": "Lists recent Gmail messages, optionally filtered by a search query.",
        "parameters": [
          { "name": "q", "in": "query", "description": "Gmail search query", "required": false, "schema": { "type": "string" } },
          { "name": "limit", "in": "query", "description": "Maximum number of messages", "required": false, "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": {
            "description": "Messages list",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": { "type": "boolean" },
                    "messages": { "type": "array", "items": { "type": "object" } },
                    "count": { "type": "integer" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/workspace/drive/upload": {
      "post": {
        "operationId": "driveUploadFile",
        "summary": "Upload a file to Google Drive",
        "description": "Uploads a local file from the server to Google Drive.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["name", "filePath"],
                "properties": {
                  "name": { "type": "string", "description": "File name in Drive" },
                  "filePath": { "type": "string", "description": "Server-side file path (relative to repo root)" },
                  "folderId": { "type": "string", "description": "Target Google Drive folder ID (optional)" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "File uploaded",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": { "type": "boolean" },
                    "fileId": { "type": "string" },
                    "webViewLink": { "type": "string" }
                  }
                }
              }
            }
          },
          "500": { "description": "Error", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Lead": {
        "type": "object",
        "required": ["company"],
        "properties": {
          "company": { "type": "string", "description": "Company name" },
          "city": { "type": "string", "description": "City" },
          "state": { "type": "string", "description": "State abbreviation" },
          "phone": { "type": "string", "description": "Phone number" },
          "email": {
            "type": "string",
            "format": "email",
            "description": "Email address"
          },
          "website": {
            "type": "string",
            "format": "uri",
            "description": "Website URL"
          },
          "rating": {
            "type": "number",
            "minimum": 0,
            "maximum": 5,
            "description": "Google rating"
          },
          "reviews": {
            "type": "integer",
            "minimum": 0,
            "description": "Number of reviews"
          }
        }
      },
      "StatusResponse": {
        "type": "object",
        "properties": {
          "status": { "type": "string" },
          "lead_count": { "type": "integer" },
          "pending_tasks": { "type": "integer" },
          "timestamp": { "type": "string", "format": "date-time" }
        }
      },
      "LeadsResponse": {
        "type": "object",
        "properties": {
          "leads": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/Lead" }
          },
          "count": { "type": "integer" }
        }
      },
      "TasksResponse": {
        "type": "object",
        "properties": {
          "tasks": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "ID": { "type": "string" },
                "TASK": { "type": "string" },
                "PHASE": { "type": "string" },
                "STATUS": { "type": "string" },
                "PRIORITY": { "type": "string" }
              }
            }
          },
          "count": { "type": "integer" }
        }
      },
      "OutreachTemplate": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "subject": { "type": "string" },
          "message": { "type": "string" }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "error": { "type": "string" }
        }
      },
      "ValidationSummary": {
        "type": "object",
        "properties": {
          "total": { "type": "integer" },
          "valid": { "type": "integer" },
          "invalid": { "type": "integer" },
          "unique": { "type": "integer" },
          "duplicates": { "type": "integer" },
          "generated_at": { "type": "string", "format": "date-time" }
        }
      }
    }
  }
}
