# PostgreSQL connection settings
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=lead_intelligence
DATABASE_USER=lead_admin
DATABASE_PASSWORD=CHANGE_ME
# Set to "true" if the DB requires TLS/SSL
DATABASE_SSL=false
# Set to "false" ONLY in development to skip TLS certificate verification
DATABASE_SSL_REJECT_UNAUTHORIZED=true

# Google Workspace / outreach settings
GOOGLE_WORKSPACE_EMAIL=
OUTREACH_PHONE=

# ── AI Agent Backend ────────────────────────────────────────────────────────
# URL of the Python FastAPI agent server (agents/server.py)
# Set NEXT_PUBLIC_AGENT_URL in the dashboard to point to this server.
AGENT_PORT=8000
NEXT_PUBLIC_AGENT_URL=http://localhost:8000

# OpenAI key for LangChain / Open Interpreter (optional)
OPENAI_API_KEY=

# SMTP settings for outreach emails
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
FROM_NAME=XPS Intelligence

# GitHub token for workflow triggering
GITHUB_TOKEN=
GITHUB_REPOSITORY=InfinityXOneSystems/XPS_INTELLIGENCE_SYSTEM

