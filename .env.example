# PostgreSQL connection settings
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=lead_intelligence
DATABASE_USER=lead_admin
DATABASE_PASSWORD=CHANGE_ME
# Set to "true" if the DB requires TLS/SSL
DATABASE_SSL=false
# Set to "false" ONLY in development to skip TLS certificate verification
DATABASE_SSL_REJECT_UNAUTHORIZED=true

# Google Workspace / outreach settings
GOOGLE_WORKSPACE_EMAIL=
OUTREACH_PHONE=

# ── AI Agent Backend ────────────────────────────────────────────────────────
# URL of the Python FastAPI agent server
AGENT_PORT=8000
NEXT_PUBLIC_AGENT_URL=http://localhost:8000

# ── API Gateway ────────────────────────────────────────────────────────────
# Express API gateway port (default 3000, matches frontend expectation)
PORT=3000

# CORS: comma-separated list of allowed frontend origins (leave blank = allow all for local dev)
# CORS_ALLOWED_ORIGINS=https://your-app.vercel.app,http://localhost:3000

# ── LLM Configuration ──────────────────────────────────────────────────────
# Smart router mode: auto | groq | ollama | openai
LLM_PROVIDER=auto

# Groq cloud LLM (fastest; recommended for cloud deployments)
GROQ_API_KEY=
GROQ_MODEL=llama3-8b-8192

# Ollama local LLM (free; requires running Ollama daemon)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# OpenAI (fallback)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# SMTP settings for outreach emails
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
FROM_NAME=XPS Intelligence

# GitHub token for workflow triggering
GITHUB_TOKEN=
GITHUB_REPOSITORY=InfinityXOneSystems/XPS_INTELLIGENCE_SYSTEM

# Vercel frontend URL (added to CORS allowlist automatically)
FRONTEND_URL=
VERCEL_URL=

