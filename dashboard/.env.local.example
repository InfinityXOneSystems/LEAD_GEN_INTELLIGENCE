# ============================================================
# XPS Intelligence – Dashboard Environment Variables
# ============================================================
# Copy this file to .env.local for local development:
#   cp .env.local.example .env.local
#
# Production values are set in the Vercel dashboard.
# ============================================================

# ----------------------------------------------------------
# Backend API URL
#   Dev:  http://localhost:8000
#   Prod: https://your-railway-app.up.railway.app
# ----------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:8000

# ----------------------------------------------------------
# Gateway / Express server (legacy — optional)
#   Dev:  http://localhost:3200
#   Prod: https://your-gateway.up.railway.app
# ----------------------------------------------------------
NEXT_PUBLIC_GATEWAY_URL=http://localhost:3200
