# .env.local.example
# ====================
# Local Docker Desktop environment variables for XPS Intelligence Platform
#
# Copy this file to .env.local and fill in your values.
# Location: C:\XPS_PLATFORM\XPS_INTELLIGENCE_SYSTEM\.env.local
#
# NOTE: .env.local is gitignored — never commit real secrets.

# ── Local paths (Docker volume mounts) ──────────────────────────────────────
# Adjust to your actual paths if different from the default layout
XPS_BACKEND_PATH=../XPS_INTELLIGENCE_SYSTEM
XPS_FRONTEND_PATH=../../XPS-INTELLIGENCE-FRONTEND
XPS_LEADS_PATH=../../LEADS

# ── Supabase (primary lead storage) ─────────────────────────────────────────
# These MUST match what's set in your Vercel project environment variables
NEXT_PUBLIC_SUPABASE_URL=https://nxfbfbipjsfzoefpgrof.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=           # Get from Supabase Dashboard → Settings → API
SUPABASE_SERVICE_ROLE_KEY=               # Get from Supabase Dashboard → Settings → API (keep secret!)

# ── GitHub ───────────────────────────────────────────────────────────────────
GITHUB_TOKEN=                            # Personal Access Token with repo write access
                                         # Used to push to InfinityXOneSystems/LEADS

# ── Backend (local only) ────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./data/local.db   # SQLite for local dev (NOT for leads)
SECRET_KEY=local-dev-key-change-me
PORT=3000
AGENT_PORT=8000

# ── LLM ────────────────────────────────────────────────────────────────────
LLM_PROVIDER=ollama                      # Use local Ollama for dev
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.2

# ── Vercel (for smoke tests and preview) ────────────────────────────────────
VERCEL_TOKEN=                            # Vercel personal token (optional for local)
VITE_API_URL=http://localhost:3000
